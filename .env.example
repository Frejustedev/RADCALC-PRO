# Firebase configuration for RadCalc Pro (single center: IMeNA, Côte d'Ivoire).
# Copy this file to ".env.local" and fill in the values from the Firebase console:
#   Console → Paramètres du projet → Vos applications → Application Web → SDK setup & config.
#
# These web-config values are NOT secrets (they identify the project, not authorise access).
# Access is controlled by Firebase Authentication + Firestore security rules (firestore.rules).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Named Firestore database DEDICATED to RadCalc Pro.
# IMPORTANT: do NOT point this (or firebase.json) at the NucleAtlas database
# "ai-studio-77e401c9-..." — deploying rules there overwrites NucleAtlas's rules
# and breaks that site. RadCalc must use its own database "radcalc-pro"
# (create it once billing/Blaze is enabled on the project).
VITE_FIREBASE_DATABASE_ID=radcalc-pro
